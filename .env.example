# Copy to .env and fill in values.

# ── SharePoint ──────────────────────────────────────────────────────────────────
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_app_client_id
AZURE_CLIENT_SECRET=your_app_client_secret
SHAREPOINT_HOSTNAME=yourtenant.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/YourSiteName
SHAREPOINT_ROOT_PATH=Path/To/The/Workflow Files Folder

# ── Mirror ──────────────────────────────────────────────────────────────────────
# Where to save the local copy of SharePoint files.
MIRROR_DIR=./local_files
# Seconds between delta polls after the initial download.
POLL_INTERVAL=60
# Number of parallel download workers for the initial sync.
DOWNLOAD_WORKERS=16

# ── opencode ────────────────────────────────────────────────────────────────────
# Path to the opencode binary (default: opencode, assumes it's in PATH).
OPENCODE_PATH=opencode
# Model to use for search queries.
OPENCODE_MODEL=opencode/big-pickle
# Timeout in seconds for each search query.
OPENCODE_TIMEOUT=120

# ── HTTP server ─────────────────────────────────────────────────────────────────
PORT=8001
HOST=0.0.0.0
ALLOWED_HOSTS=localhost:8001,localhost,your-app.up.railway.app

# Bootstrap bearer tokens: label:token,label:token
AUTH_TOKENS=pm:changeme123

# ── Admin panel ─────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_JWT_SECRET=change-this-to-a-long-random-string
